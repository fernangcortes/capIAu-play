<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base CapIAu Theme (dark, TV-optimized) -->
    <style name="Theme.CapIAu" parent="@style/Theme.Leanback">
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowBackground">@color/capiau_dark</item>
        <item name="android:colorPrimary">@color/capiau_red</item>
        <item name="android:colorAccent">@color/capiau_accent</item>
        <item name="android:textColorPrimary">@color/capiau_text_primary</item>
        <item name="android:textColorSecondary">@color/capiau_text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
        
        <!-- Leanback specific -->
        <item name="browseTitleTextColor">@color/capiau_text_primary</item>
        <item name="browseRowsMarginTop">60dp</item>
        <item name="defaultBrandColor">@color/capiau_red</item>
        <item name="defaultSearchColor">@color/capiau_red</item>
    </style>

    <!-- Player Theme (no title bar, full immersive) -->
    <style name="Theme.CapIAu.Player" parent="Theme.CapIAu">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>
